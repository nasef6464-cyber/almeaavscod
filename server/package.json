    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:status": "tsx scripts/migrate.ts status",
    "db:studio": "tsx scripts/migrate.ts studio",
    "migrate:pg": "tsx src/scripts/migrateToPostgres.ts",
    "seed:admin": "tsx src/scripts/seedAdmin.ts",
    "seed:platform": "tsx src/scripts/seedPlatformData.ts",
    "seed:courses:api": "tsx src/scripts/seedCoursesViaApi.ts",
    "seed:users": "tsx src/scripts/seedDemoUsers.ts",
    "seed:operational": "tsx src/scripts/seedOperationalScenario.ts",
    "seed:operational:api": "tsx src/scripts/seedOperationalScenarioApi.ts",
    "seed:learning:api": "tsx src/scripts/seedLearningInventoryApi.ts",
