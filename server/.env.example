# ============================================================
# Server Environment Variables
# ============================================================
PORT=4000
CLIENT_URL=http://localhost:3000

# ---- Database ----
# MongoDB (legacy fallback)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/the-hundred
# PostgreSQL (Supabase - primary)
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
USE_POSTGRES=true

# ---- Auth ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Admin Bootstrap ----
DEV_LOCAL_ADMIN_BYPASS=false
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ---- AI Providers (optional) ----
AI_PROVIDER=
AI_REQUEST_TIMEOUT_MS=15000
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=local-model
